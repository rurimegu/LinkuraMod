<Project Sdk="Godot.NET.Sdk/4.5.1">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>RuriMegu</RootNamespace>
    <Version>0.1.6.0</Version>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="Sts2Core">
      <HintPath>libs\sts2.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Alchyr.Sts2.BaseLib" Version="*">
      <ExcludeAssets>runtime</ExcludeAssets>
      <Private>False</Private>
    </PackageReference>
    <PackageReference Include="Alchyr.Sts2.ModAnalyzers" Version="*" />
    <PackageReference Include="Lib.Harmony" Version="2.*" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="LinkuraMod/localization/**/*.json" />
  </ItemGroup>
</Project>
